<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive-icon background: base colour + a small radial highlight tucked
  into the top-left corner to give the icon a subtle glass sheen without
  washing the whole face.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <color android:color="@color/ic_launcher_background" />
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:centerX="0.15"
                android:centerY="0.15"
                android:gradientRadius="28%p"
                android:startColor="#33FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>

</layer-list>
