<?xml version="1.0" encoding="utf-8"?>
<!--
  Bold-scheme tile background. Flat solid fill, no gradient — the per-slot
  colour is applied at runtime via RemoteViews.setInt("setBackgroundColor")
  in ShortcutWidgetProvider (the colour declared here is just a placeholder
  for previewing the layout in Android Studio).

  Corner radius bumped 16 dp → 20 dp for a slightly rounder, more modern
  silhouette. Stays well shy of pill-shaped so the tiles still read as
  "blocks" the bold style is built around.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#FF4F46E5" />
    <corners android:radius="20dp" />
</shape>
