<?xml version="1.0" encoding="utf-8"?>
<!--
  Bold widget layout — 12 fixed-size 1×1-icon tiles in a GridLayout.

  The grid's columnCount is set at runtime by
  ShortcutWidgetProvider#buildBoldViews based on the current widget width,
  so the tiles wrap into as many columns as fit and the remainder are
  hidden via View.GONE. Each tile is a fixed 80 dp × 80 dp with a 48 dp
  icon — no weight, no resizing — that's the "1×1 icon, no resizing"
  behaviour. SLOT_DP in ShortcutWidgetProvider must stay in sync with
  the 80dp value here.

  An outer FrameLayout centres the grid so leftover space sits as an even
  margin around the tiles rather than collecting on one side.

  rowCount=2 and columnCount=6 in XML are defaults for the layout preview
  in Android Studio; runtime overrides them through setInt("setColumnCount", …).
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <GridLayout
        android:id="@+id/shortcut_grid"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:columnCount="6"
        android:rowCount="2"
        android:padding="2dp"
        android:useDefaultMargins="false">

        <LinearLayout
            android:id="@+id/slot_0"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_margin="2dp"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="6dp"
            android:background="@drawable/widget_bold_bg"
            android:foreground="@drawable/widget_bold_overlay"
            android:foregroundGravity="fill"
            android:visibility="gone">
            <ImageView
                android:id="@+id/icon_0"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:scaleType="fitCenter"
                android:adjustViewBounds="true"
                android:tint="#FFFFFFFF"
                android:src="@android:drawable/ic_menu_mylocation" />
            <TextView
                android:id="@+id/label_0"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#FFFFFFFF"
                android:shadowColor="#66000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:maxLines="1"
                android:ellipsize="end"
                android:paddingTop="2dp" />
        </LinearLayout>

